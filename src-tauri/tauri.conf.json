{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Here to Slay DUNGEONS Mapper",
  "version": "0.1.0",
  "identifier": "com.rodclemen.heretoslay.mapper",
  "build": {
    "beforeDevCommand": "npm run build:tauri-web",
    "beforeBuildCommand": "npm run build:tauri-web",
    "frontendDist": "../dist/tauri"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Here to Slay: DUNGEONS Mapper",
        "width": 1440,
        "height": 1150,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; connect-src 'self' blob: ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Rod Clemen",
    "copyright": "Copyright © 2026 Rod Clemen",
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
