{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HtSDMapper",
  "version": "0.8.3",
  "identifier": "com.rodclemen.heretoslay.mapper",
  "build": {
    "beforeDevCommand": "npm run build:tauri-web",
    "beforeBuildCommand": "npm run build:tauri-web",
    "frontendDist": "../dist/tauri"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Here to Slay: DUNGEONS Mapper",
        "width": 1440,
        "height": 1150,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; connect-src 'self' blob: ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/rodclemen/here_to_slay_dungeons_mapper/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVCMTY4MzUwRDUwQUQyNzEKUldSeDBnclZVSU1XVzRWa3F6ajBEbXlHZjJxeitpdmdTTEpuazUzdHB4WGlqaXBneFhrTmhZWnIK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "publisher": "Rod Clemen",
    "copyright": "Copyright © 2026 Rod Clemen",
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
